# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# data
/data/*.db
/data/*.db-wal
/data/*.db-shm
!/data/jlpt-seed.db
/data/debug/
/data/*.json

# scripts (debug/utility — only export-seed.ts is needed)
/scripts/analyze-data.ts
/scripts/build-seed.ts
/scripts/dump-data.ts

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
